{
  "name": "smart-accountant-legacy",
  "productName": "Smart Accountant",
  "version": "1.0.0",
  "description": "Smart Accountant — Legacy Windows 7 (32/64-bit) desktop build (Electron 22)",
  "private": true,
  "main": "main.js",
  "author": "Smart Accountant",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --ia32 --x64",
    "dist:win32": "electron-builder --win --ia32",
    "dist:win64": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.smartaccountant.legacy",
    "productName": "SmartAccountant",
    "asar": true,
    "directories": {
      "output": "out",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["ia32", "x64"] }
      ],
      "icon": "assets/app.ico",
      "artifactName": "SmartAccountantSetup-Win7-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Accountant",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
