{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartAccountant",
  "version": "0.2.0",
  "//identifier": "FROZEN — changing this orphans every user's IndexedDB. Do not edit.",
  "identifier": "com.smartaccountant.app",

  "build": {
    "beforeBuildCommand": "bun run build:tauri",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist/client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Smart Accountant",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "//deleteAppDataOnUninstall": "OFF — user data under %LOCALAPPDATA%\\com.smartaccountant.app\\ is preserved on uninstall so re-installs never wipe accounting data. Users who want a true clean uninstall can delete the folder by hand.",
        "deleteAppDataOnUninstall": false
      },
      "wix": {
        "//upgradeCode": "FROZEN — changing this makes MSI upgrades run as brand-new installs and can trigger a data-folder wipe. Do not edit.",
        "upgradeCode": "F7E5A1C2-4B6D-4C8A-9F2E-1A3B5C7D9E11"
      },
      "allowDowngrades": false

    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {
      "preload": []
    }
  }
}
