{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities: shell + dialog + filesystem scoped to the per-user local-app-data root (%LOCALAPPDATA%\\com.smartaccountant.app). Silent writes can only happen inside this root so that Windows installer upgrades never touch user data. The user-picker capability is what permits user-chosen 'Save as…' writes to Documents / Downloads / Desktop.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://your-smart-accountant.lovable.app",
      "https://your-smart-accountant.lovable.app/*",
      "https://*.lovable.app",
      "https://*.lovable.app/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "shell:allow-open",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA" }
      ]
    }
  ]
}
