{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Smart Accountant",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://your-smart-accountant1.lovable.app",
      "https://your-smart-accountant1.lovable.app/*",
      "https://*.lovable.app",
      "https://*.lovable.app/*"
    ]
  },
  "permissions": [
    "core:default",

    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-hide",

    "shell:default",
    "shell:allow-open",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",

    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",

    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },

    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
